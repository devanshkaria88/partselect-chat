# Copy to .env and fill in keys. Compose reads this file automatically.
# Boot (make up) needs NO keys — only the offline data-prep + backend need them.

# ── Postgres ─────────────────────────────────────────────────────────────────────
POSTGRES_DB=partselect
POSTGRES_USER=partselect
POSTGRES_PASSWORD=partselect
POSTGRES_PORT=5432
# For host-run tools (Prisma CLI, seed/embed scripts). In-container services build
# their own URL against the compose service host `db`.
DATABASE_URL=postgresql://partselect:partselect@localhost:5432/partselect

# ── LLM — backend agent (Phase 3). Get from https://console.anthropic.com ─────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ── Embeddings — offline `make embed` only (Phase 2). https://www.voyageai.com ────
VOYAGE_API_KEY=pa-xxxxxxxx

# ── Agent tuning ─────────────────────────────────────────────────────────────────
# Sliding-window size (messages of chat history replayed to the model each turn).
SESSION_WINDOW_MESSAGES=20

# ── Service ports / wiring ───────────────────────────────────────────────────────
BACKEND_PORT=3001
FRONTEND_PORT=3000
# Server-to-server URL the Next.js route handler uses to reach NestJS (Phase 5).
INTERNAL_API_URL=http://backend:3001
